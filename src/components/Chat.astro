---
// Chat — toggled open/closed via data-chat-open / data-chat-close attributes.
---

<div
  id="chat-panel"
  role="dialog"
  aria-modal="true"
  aria-label="Live chat"
  class="hidden fixed bottom-20 left-6 z-30 flex flex-col w-[500px] h-[420px] overflow-hidden"
  style="background: rgba(220,215,205,0.9); mix-blend-mode: hard-light; box-shadow: 0 0 0 1px rgba(0,0,0,0.12);"
>
  <div
    class="flex items-center justify-between px-3 py-1.5 border-b border-black/10"
  >
    <span
      class="font-serif"
      aria-hidden="true"
      style="font-size:0.7rem; letter-spacing:0.1em; text-transform:uppercase; opacity:0.5;"
      >Chat</span
    >
    <button
      data-chat-close
      aria-label="Close chat"
      class="bg-transparent border-none cursor-pointer"
      style="font-size:0.75rem; opacity:0.5;">&times;</button
    >
  </div>
  <iframe
    title="Community Radio Live Chat"
    src="https://app.radiocult.fm/embed/chat/seyisfjorur-community-radio?theme=light&primaryColor=%23000000&corners=sharp"
    class="flex-1 w-full border-0"
    allow="microphone"></iframe>
</div>

<script is:inline>
  const panel = document.getElementById("chat-panel");

  document.addEventListener("click", (e) => {
    if (e.target.closest("[data-chat-open]")) {
      e.preventDefault();
      panel.classList.remove("hidden");
    }
    if (e.target.closest("[data-chat-close]")) {
      panel.classList.add("hidden");
    }
  });
</script>
